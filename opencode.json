{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "next-devtools": {
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "type": "local"
    },
    "vercel": {
      "command": ["npx", "mcp-remote"],
      "url": "https://mcp.vercel.com",
      "enabled": true,
      "type": "remote"
    }
  }
}
